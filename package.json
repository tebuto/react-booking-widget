{
    "name": "@tebuto/react-booking-widget",
    "version": "1.3.6",
    "description": "React Component for the Tebuto Booking Widget",
    "author": "Artus Engineering GmbH",
    "homepage": "https://tebuto.de",
    "license": "MIT",
    "main": "dist/cjs/index.js",
    "module": "dist/esm/index.js",
    "types": "dist/types.d.ts",
    "scripts": {
        "dev": "storybook dev -p 6006",
        "build:storybook": "storybook build",
        "test": "jest --coverage",
        "build": "rollup -c --bundleConfigAsCjs",
        "prepare": "husky",
        "lint": "biome lint .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write --error-on-warnings .",
        "biome:migrate": "biome migrate --write"
    },
    "peerDependencies": {
        "react": "^19",
        "react-dom": "^19"
    },
    "devDependencies": {
        "@babel/core": "8.0.1",
        "@babel/preset-env": "8.0.2",
        "@babel/preset-react": "8.0.1",
        "@babel/preset-typescript": "8.0.1",
        "@biomejs/biome": "2.5.4",
        "@rollup/plugin-commonjs": "29.0.3",
        "@rollup/plugin-node-resolve": "16.0.3",
        "@rollup/plugin-terser": "1.0.0",
        "@rollup/plugin-typescript": "12.3.0",
        "@storybook/react": "10.5.2",
        "@storybook/react-vite": "10.5.2",
        "@testing-library/react": "16.3.2",
        "@types/jest": "30.0.0",
        "@types/react": "19.2.17",
        "@vitejs/plugin-react": "6.0.3",
        "babel-jest": "30.4.1",
        "husky": "9.1.7",
        "jest": "30.4.2",
        "jest-environment-jsdom": "30.4.1",
        "msw": "2.15.0",
        "rollup": "4.62.2",
        "rollup-plugin-dts": "6.4.1",
        "rollup-plugin-peer-deps-external": "2.2.4",
        "storybook": "10.5.2",
        "tslib": "2.8.1",
        "typescript": "6.0.3",
        "vite": "8.1.5"
    },
    "jest": {
        "testEnvironment": "jsdom",
        "setupFilesAfterEnv": [
            "<rootDir>/src/setupTests.ts"
        ],
        "collectCoverageFrom": [
            "src/**/*.{ts,tsx}",
            "!src/**/*.test.{ts,tsx}",
            "!src/**/*.stories.tsx",
            "!src/mocks/**",
            "!src/components/examples/**",
            "!src/setupTests.ts",
            "!src/index.ts"
        ],
        "coverageReporters": [
            "lcov",
            "text-summary"
        ]
    },
    "babel": {
        "presets": [
            "@babel/preset-env",
            "@babel/preset-typescript",
            [
                "@babel/preset-react",
                {
                    "runtime": "automatic"
                }
            ]
        ]
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/tebuto/react-booking-widget.git"
    },
    "bugs": {
        "url": "https://github.com/tebuto/react-booking-widget/issues"
    },
    "engines": {
        "node": ">=24"
    },
    "keywords": [
        "appointment",
        "booking",
        "calendar",
        "react",
        "tebuto",
        "widget",
        "online",
        "therapist",
        "psychologist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "msw": {
        "workerDirectory": [
            "public"
        ]
    }
}
